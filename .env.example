DATABASE_URL=postgresql://postgres:password@localhost:5432/aurora
AUTH_SECRET=generate-a-secret-with-npx-auth-secret
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# GitHub OAuth App settings:
# - Homepage URL: https://aurora-ascent.vercel.app
# - Authorization callback URL: https://aurora-ascent.vercel.app/api/auth/callback/github

# Optional: cap new user registrations (does not block existing users from signing back in).
# Set to an integer to enable, e.g. MAX_USERS=500. Unset = no limit.
# Test locally: set MAX_USERS=<current_user_count> and try signing in with a new account.
# MAX_USERS=500

# Required in production for the Supabase keep-alive cron job (/api/cron/ping).
# Generate any random secret: openssl rand -base64 32
# Add the same value in Vercel → Settings → Environment Variables.
# CRON_SECRET=your-random-secret-here
